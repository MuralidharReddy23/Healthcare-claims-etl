{
    "name": "df_claims_transactions_transform",
    "properties": {
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "dataset": {
                        "referenceName": "ds_claims_transactions_raw_sql",
                        "type": "DatasetReference"
                    },
                    "name": "sourceClaimsTransactionsRaw"
                }
            ],
            "sinks": [
                {
                    "dataset": {
                        "referenceName": "ds_claims_transactions_curated_sql",
                        "type": "DatasetReference"
                    },
                    "name": "sinkClaimsTransactionsCurated"
                }
            ],
            "transformations": [
                {
                    "name": "derivedClaimsTransactions"
                },
                {
                    "name": "selectClaimsTransactions"
                }
            ],
            "scriptLines": [
                "source(output(",
                "          ID as string,",
                "          CLAIMID as string,",
                "          CHARGEID as string,",
                "          PATIENTID as string,",
                "          TYPE as string,",
                "          AMOUNT as string,",
                "          METHOD as string,",
                "          FROMDATE as string,",
                "          TODATE as string,",
                "          PLACEOFSERVICE as string,",
                "          PROCEDURECODE as string,",
                "          MODIFIER1 as string,",
                "          MODIFIER2 as string,",
                "          DIAGNOSISREF1 as string,",
                "          DIAGNOSISREF2 as string,",
                "          DIAGNOSISREF3 as string,",
                "          DIAGNOSISREF4 as string,",
                "          UNITS as string,",
                "          DEPARTMENTID as string,",
                "          NOTES as string,",
                "          UNITAMOUNT as string,",
                "          TRANSFEROUTID as string,",
                "          TRANSFERTYPE as string,",
                "          PAYMENTS as string,",
                "          ADJUSTMENTS as string,",
                "          TRANSFERS as string,",
                "          OUTSTANDING as string,",
                "          APPOINTMENTID as string,",
                "          LINENOTE as string,",
                "          PATIENTINSURANCEID as string,",
                "          FEESCHEDULEID as string,",
                "          PROVIDERID as string,",
                "          SUPERVISINGPROVIDERID as string",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     format: 'table') ~> sourceClaimsTransactionsRaw",
                "sourceClaimsTransactionsRaw derive(transaction_id = ID,",
                "          claim_id = CLAIMID,",
                "          patient_id = PATIENTID,",
                "          provider_id = PROVIDERID,",
                "          transaction_type = upper(TYPE),",
                "          amount = toFloat(AMOUNT),",
                "          payment_method = upper(METHOD),",
                "          from_date = toDate(FROMDATE),",
                "          to_date = toDate(TODATE),",
                "          place_of_service = PLACEOFSERVICE,",
                "          procedure_code = PROCEDURECODE,",
                "          units = toInteger(UNITS),",
                "          unit_amount = toFloat(UNITAMOUNT),",
                "          payments = toFloat(PAYMENTS),",
                "          adjustments = toFloat(ADJUSTMENTS),",
                "          transfers = toFloat(TRANSFERS),",
                "          outstanding = toFloat(OUTSTANDING)) ~> derivedClaimsTransactions",
                "derivedClaimsTransactions select(mapColumn(",
                "          transaction_id,",
                "          claim_id,",
                "          patient_id,",
                "          provider_id,",
                "          transaction_type,",
                "          amount = derivedClaimsTransactions@amount,",
                "          payment_method,",
                "          from_date,",
                "          to_date,",
                "          place_of_service,",
                "          procedure_code,",
                "          units = derivedClaimsTransactions@units,",
                "          unit_amount,",
                "          payments = derivedClaimsTransactions@payments,",
                "          adjustments = derivedClaimsTransactions@adjustments,",
                "          transfers = derivedClaimsTransactions@transfers,",
                "          outstanding = derivedClaimsTransactions@outstanding",
                "     ),",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true) ~> selectClaimsTransactions",
                "selectClaimsTransactions sink(allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     input(",
                "          transaction_id as string,",
                "          claim_id as string,",
                "          patient_id as string,",
                "          provider_id as string,",
                "          transaction_type as string,",
                "          amount as double,",
                "          payment_method as string,",
                "          from_date as date,",
                "          to_date as date,",
                "          place_of_service as string,",
                "          procedure_code as string,",
                "          units as integer,",
                "          unit_amount as double,",
                "          payments as double,",
                "          adjustments as double,",
                "          transfers as double,",
                "          outstanding as double",
                "     ),",
                "     deletable:false,",
                "     insertable:true,",
                "     updateable:false,",
                "     upsertable:false,",
                "     truncate:true,",
                "     format: 'table',",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true,",
                "     errorHandlingOption: 'stopOnFirstError',",
                "     mapColumn(",
                "          transaction_id,",
                "          claim_id,",
                "          patient_id,",
                "          provider_id,",
                "          transaction_type,",
                "          amount,",
                "          payment_method,",
                "          from_date,",
                "          to_date,",
                "          place_of_service,",
                "          procedure_code,",
                "          units,",
                "          unit_amount,",
                "          payments,",
                "          adjustments,",
                "          transfers,",
                "          outstanding",
                "     )) ~> sinkClaimsTransactionsCurated"
            ]
        }
    }
}
