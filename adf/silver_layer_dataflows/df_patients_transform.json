{
    "name": "df_patients_transform",
    "properties": {
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "dataset": {
                        "referenceName": "ds_patients_raw_sql",
                        "type": "DatasetReference"
                    },
                    "name": "patientsSourceRaw"
                }
            ],
            "sinks": [
                {
                    "dataset": {
                        "referenceName": "ds_patients_curated_sql",
                        "type": "DatasetReference"
                    },
                    "name": "sink1"
                }
            ],
            "transformations": [
                {
                    "name": "derivedPatientsCurated"
                },
                {
                    "name": "select1"
                }
            ],
            "scriptLines": [
                "source(output(",
                "          Id as string,",
                "          BIRTHDATE as string,",
                "          DEATHDATE as string,",
                "          SSN as string,",
                "          DRIVERS as string,",
                "          PASSPORT as string,",
                "          PREFIX as string,",
                "          FIRST as string,",
                "          MIDDLE as string,",
                "          LAST as string,",
                "          SUFFIX as string,",
                "          MAIDEN as string,",
                "          MARITAL as string,",
                "          RACE as string,",
                "          ETHNICITY as string,",
                "          GENDER as string,",
                "          BIRTHPLACE as string,",
                "          ADDRESS as string,",
                "          CITY as string,",
                "          STATE as string,",
                "          COUNTY as string,",
                "          FIPS as string,",
                "          ZIP as string,",
                "          LAT as string,",
                "          LON as string,",
                "          HEALTHCARE_EXPENSES as string,",
                "          HEALTHCARE_COVERAGE as string,",
                "          INCOME as string",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     format: 'table') ~> patientsSourceRaw",
                "patientsSourceRaw derive(birth_date = toDate(BIRTHDATE),",
                "          death_date = toDate(DEATHDATE),",
                "          income = toFloat(INCOME),",
                "          healthcare_expenses = toFloat(HEALTHCARE_EXPENSES),",
                "          healthcare_coverage = toFloat(HEALTHCARE_COVERAGE),",
                "          city = upper(CITY),",
                "          state = upper(STATE)) ~> derivedPatientsCurated",
                "derivedPatientsCurated select(mapColumn(",
                "          Id,",
                "          SSN,",
                "          DRIVERS,",
                "          PASSPORT,",
                "          PREFIX,",
                "          first_name = FIRST,",
                "          MIDDLE,",
                "          last_name = LAST,",
                "          SUFFIX,",
                "          MAIDEN,",
                "          MARITAL,",
                "          race = RACE,",
                "          ethnicity = ETHNICITY,",
                "          gender = GENDER,",
                "          BIRTHPLACE,",
                "          ADDRESS,",
                "          city = derivedPatientsCurated@city,",
                "          state = derivedPatientsCurated@state,",
                "          county = COUNTY,",
                "          FIPS,",
                "          zip = ZIP,",
                "          LAT,",
                "          LON,",
                "          birth_date,",
                "          death_date,",
                "          income = derivedPatientsCurated@income,",
                "          healthcare_expenses = derivedPatientsCurated@healthcare_expenses,",
                "          healthcare_coverage = derivedPatientsCurated@healthcare_coverage,",
                "          city = derivedPatientsCurated@city,",
                "          state = derivedPatientsCurated@state",
                "     ),",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true) ~> select1",
                "select1 sink(allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     input(",
                "          patient_id as string,",
                "          birth_date as date,",
                "          death_date as date,",
                "          first_name as string,",
                "          last_name as string,",
                "          gender as string,",
                "          race as string,",
                "          ethnicity as string,",
                "          city as string,",
                "          state as string,",
                "          county as string,",
                "          zip as string,",
                "          income as double,",
                "          healthcare_expenses as double,",
                "          healthcare_coverage as double",
                "     ),",
                "     deletable:false,",
                "     insertable:true,",
                "     updateable:false,",
                "     upsertable:false,",
                "     truncate:true,",
                "     format: 'table',",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true,",
                "     errorHandlingOption: 'stopOnFirstError',",
                "     mapColumn(",
                "          patient_id = Id,",
                "          birth_date,",
                "          death_date,",
                "          first_name,",
                "          last_name,",
                "          gender,",
                "          race,",
                "          ethnicity,",
                "          city,",
                "          state,",
                "          county,",
                "          zip,",
                "          income,",
                "          healthcare_expenses,",
                "          healthcare_coverage",
                "     )) ~> sink1"
            ]
        }
    }
}
